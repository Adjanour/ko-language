import std.List

type List a = Cons a (List a) | Nil

fn double x = x * 2
fn add10 x = x + 10

fn sum_list xs =
  List.sum xs

fn main =
  let nums = Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 Nil))))
  let a = 5 |> add10 |> double
  let b = 3 |> double |> add10
  println (a + b)
  println (sum_list nums)