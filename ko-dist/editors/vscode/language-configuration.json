{
  "comments": {
    "lineComment": "#",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(fn|type|module|match|if)\\b",
      "end": "^\\s*(fn|type|module|match|let)\\b|^$"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(fn|let|match|if|type|module)\\b.*[=:]\\s*$",
    "decreaseIndentPattern": "^\\s*$"
  },
  "wordPattern": "(-?\\d+\\.\\d*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\=\\+\\{\\}\\\\\\|\\;:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}
