# Fibonacci numbers -- classic recursive implementation
# Demonstrates: basic recursion, pattern matching, if-then-else

fn fib n =
  if n <= 1 then n
  else fib (n - 1) + fib (n - 2)

fn main =
  println "Fibonacci numbers:"
  println (fib 0)
  println (fib 1)
  println (fib 5)
  println (fib 10)
  println (fib 20)
