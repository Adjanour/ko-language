# Ackermann Function -- classic recursive function
# Demonstrates: deep recursion, stack overflow detection

fn ack m n =
  if m == 0 then n + 1
  else if n == 0 then ack (m - 1) 1
  else ack (m - 1) (ack m (n - 1))

fn main =
  println (ack 0 0)
  println (ack 0 1)
  println (ack 1 0)
  println (ack 1 1)
  println (ack 2 2)
  println (ack 3 3)
