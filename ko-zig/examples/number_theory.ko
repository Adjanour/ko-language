# GCD and LCM -- number theory basics
# Demonstrates: Euclidean algorithm, recursion, pattern matching

fn gcd a b =
  if b == 0 then a
  else gcd b (a % b)

fn lcm a b =
  if a == 0 then 0
  else (a / gcd a b) * b

fn main =
  println (gcd 12 8)
  println (gcd 100 75)
  println (gcd 17 13)
  println (lcm 4 6)
  println (lcm 15 20)
  println (lcm 7 5)
