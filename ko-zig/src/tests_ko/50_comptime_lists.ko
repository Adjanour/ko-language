# Test: comptime list operations
type List a = Cons a (List a) | Nil

comptime fn comptime_sum lst =
  match lst
    | Cons x rest => x + comptime_sum rest
    | Nil => 0

comptime fn comptime_length lst =
  match lst
    | Cons _ rest => 1 + comptime_length rest
    | Nil => 0

comptime fn comptime_product lst =
  match lst
    | Cons x rest => x * comptime_product rest
    | Nil => 1

comptime fn comptime_max lst =
  match lst
    | Cons x rest =>
      let rest_max = comptime_max rest
      if x > rest_max then x else rest_max
    | Nil => 0

comptime fn comptime_all_positive lst =
  match lst
    | Cons x rest => if x > 0 then comptime_all_positive rest else 0
    | Nil => 1

comptime fn comptime_count pred lst =
  match lst
    | Cons x rest => if pred x then 1 + comptime_count pred rest else comptime_count pred rest
    | Nil => 0

comptime fn comptime_is_positive n = n > 0

comptime fn comptime_is_even n = n % 2 == 0

comptime fn comptime_factorial n = if n == 0 then 1 else n * comptime_factorial (n - 1)

fn main =
  let xs = Cons 1 (Cons 2 (Cons 3 (Cons 4 Nil)))
  println (comptime comptime_sum xs)
  println (comptime comptime_length xs)
  println (comptime comptime_product xs)
  println (comptime comptime_max xs)
  println (comptime comptime_count comptime_is_even xs)
  println (comptime comptime_count comptime_is_positive xs)
  println (comptime comptime_factorial 5)
