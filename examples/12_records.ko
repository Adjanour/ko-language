# Records — Named fields in a structured type.

type Point = { x: Int, y: Int }
type Person = { name: String, age: Int }

fn distance p1 p2 =
  let dx = p1.x - p2.x
  let dy = p1.y - p2.y
  dx * dx + dy * dy

fn main =
  let origin = Point { x = 0, y = 0 }
  let pt = Point { x = 3, y = 4 }
  let d = distance origin pt
  d
