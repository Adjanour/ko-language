// Generic Types — Type parameters for reusable data structures.

type Maybe a = Just a | Nothing

fn map-maybe f mx =
  match mx
    Just x -> Just (f x)
    Nothing -> Nothing

fn main =
  let x = Just 42
  let y = map-maybe (\x -> x * 2) x
  inspect y

  let s = Just "hello"
  let t = map-maybe (\x -> len x) s
  inspect t
