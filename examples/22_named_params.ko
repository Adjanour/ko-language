# Named parameters demo
# Demonstrates: ~name parameter syntax, ~name:value call syntax

fn greet ~name ~greeting =
  println greeting
  println name

fn add ~x ~y =
  x + y

fn main =
  # Named args in definition order
  greet ~name:"Alice" ~greeting:"Hello"

  # Named args in different order (reordered by compiler)
  greet ~greeting:"Hi" ~name:"Bob"

  # Named args with add
  let result = add ~x:10 ~y:20
  println result
