# Partial Application — Currying multi-param functions.

fn add x y = x + y
fn multiply x y = x * 2
fn compose f g x = f (g x)

fn main =
  let add1 = add 1
  let add10 = add 10
  let a = add1 2
  let b = add10 5

  let double = \x -> x * 2
  let inc = \x -> x + 1
  let double_then_inc = compose inc double
  let c = double_then_inc 5

  a + b + c
