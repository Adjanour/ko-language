// 13_test.ko — Testing primitives
// assert, assert_eq, test, run_tests

fn add a b = a + b
fn mul a b = a * b
fn factorial n =
  if n == 0 then 1
  else mul n (factorial (n - 1))

fn test-arithmetic =
  assert_eq (add 1 2) 3
  assert_eq (add 0 0) 0
  assert_eq (add (-1) 1) 0
  assert_eq (mul 3 4) 12
  assert_eq (mul 0 100) 0

fn test-factorial =
  assert_eq (factorial 0) 1
  assert_eq (factorial 1) 1
  assert_eq (factorial 5) 120
  assert_eq (factorial 10) 3628800

fn test-strings =
  assert_eq (len "") 0
  assert_eq (len "hello") 5
  assert_eq (concat "hello" " world") "hello world"
  assert (starts_with "hello" "hel")
  assert (ends_with "hello" "llo")
  assert (contains "hello" "ell")

fn test-booleans =
  assert (1 == 1)
  assert (1 != 2)
  assert (1 != 2)
  assert (false == false)

fn main =
  println "=== Kō Test Suite ==="
  println ""
  test "arithmetic" test-arithmetic
  test "factorial" test-factorial
  test "strings" test-strings
  test "booleans" test-booleans
  println ""
  run_tests
