# Linked Lists — The universal data structure.

type List a = Cons a (List a) | Nil

fn sum xs =
  match xs
    | Cons x rest => x + sum rest
    | Nil => 0

fn length xs =
  match xs
    | Cons _ rest => 1 + length rest
    | Nil => 0

fn main =
  let xs = Cons 1 (Cons 2 (Cons 3 Nil))
  let s = sum xs
  let l = length xs
  s
