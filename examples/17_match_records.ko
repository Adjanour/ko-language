# Pattern Matching with Records — Destructure complex data.

type Shape = Circle (Int) | Rect (Int) (Int) | Point (Int) (Int)

fn area s =
  match s
    | Circle r => r * r
    | Rect w h => w * h
    | Point _ _ => 0

fn describe s =
  match s
    | Circle r => r
    | Rect w h => w + h
    | Point x y => x + y

fn main =
  let c = Circle 5
  let r = Rect 3 4
  let p = Point 1 2
  let a = area c
  let b = describe r
  let d = describe p
  a + b + d
