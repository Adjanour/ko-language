# Example 4: Lists with pattern matching

type List = Cons * * | Nil

fn length xs =
  match xs
    Cons _ rest -> 1 + length rest
    Nil -> 0

fn sum xs =
  match xs
    Cons x rest -> x + sum rest
    Nil -> 0

fn append xs ys =
  match xs
    Cons x rest -> Cons x (append rest ys)
    Nil -> ys

fn main =
  let xs = Cons 1 (Cons 2 (Cons 3 (Cons 4 Nil)))
  let ys = Cons 5 (Cons 6 Nil)
  print (length xs)
  print (sum xs)
  print (sum (append xs ys))
