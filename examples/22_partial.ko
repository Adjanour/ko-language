# Partial Application — Multi-level currying.

fn add x y = x + y
fn mul x y = x * y
fn compose f g x = f (g x)

fn main =
  let add1 = add 1
  let add10 = add 10
  let mul2 = mul 2
  let mul10 = mul 10

  let a = add1 2
  let b = add10 5
  let c = mul2 3
  let d = mul10 4

  let add_then_mul = compose mul2 add1
  let e = add_then_mul 5

  a + b + c + d + e
