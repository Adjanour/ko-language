// Inspect — The debug built-in for seeing types and values.

type Pair = Pair * *

fn main =
  inspect 42
  inspect 3.14
  inspect true
  inspect "hello"
  inspect 'c'

  let p = Pair 1 2
  inspect p

  println "print shows:"
  println 42

  println "inspect shows:"
  inspect 42

  // Comments: // single-line, # hash, /* multi-line */
