# Pattern Matching — Handle every case.

type Expr = Add (Expr) (Expr) | Mul (Expr) (Expr) | Lit (Int)
type Shape = Circle (Int) | Rect (Int) (Int)

fn eval e =
  match e
    | Add a b => eval a + eval b
    | Mul a b => eval a * eval b
    | Lit n => n

fn area s =
  match s
    | Circle r => r * r
    | Rect w h => w * h

fn main =
  let e = Add (Lit 1) (Mul (Lit 2) (Lit 3))
  let s = Circle 5
  let v = eval e
  let a = area s
  v
