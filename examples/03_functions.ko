// 03_functions.ko — Function definitions and recursion

fn double x = x * 2
fn square x = x * x
fn add a b = a + b

fn my-abs x =
  if x < 0 then -x
  else x

fn factorial n =
  if n == 0 then 1
  else n * factorial (n - 1)

fn fib n =
  if n <= 1 then n
  else fib (n - 1) + fib (n - 2)

fn main =
  println (double 5)
  println (square 7)
  println (add 10 20)
  println (my-abs (-42))
  println (factorial 10)
  println (fib 10)
